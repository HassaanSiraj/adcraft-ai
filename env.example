# Copy to .env.local and fill in values

# Google Gemini API Key (free tier available)
GEMINI_API_KEY=

# Hugging Face Inference API Key (free tier available)
# Used for image generation with stabilityai/stable-diffusion-2-1
HUGGINGFACE_API_KEY=

# Groq (free/fast text LLM fallback)
GROQ_API_KEY=

# OpenRouter (primary text LLM if provided)
OPENROUTER_API_KEY=
# Optional: override default model (bytedance-seed/seedream-4.5)
OPENROUTER_MODEL=


